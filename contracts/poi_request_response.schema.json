{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "POI Request Response Schema",
  "description": "Response schema for POI request submissions",
  "type": "object",
  "properties": {
    "message": {
      "type": "string",
      "description": "Human-readable response message",
      "examples": ["POI suggestion for 'Marina Bay Sands SkyPark' submitted. Will coordinate with other families when convenient."]
    },
    "request_id": {
      "type": "string",
      "description": "Unique identifier for tracking the POI request",
      "pattern": "^poi_req_[a-zA-Z0-9_]+_[0-9]+$",
      "examples": ["poi_req_family_123_1642781234"]
    },
    "event_created": {
      "type": "object",
      "description": "Event created for Decision Agent processing",
      "properties": {
        "event_id": {
          "type": "string",
          "description": "Unique event identifier",
          "examples": ["evt_poi_req_family_123_1642781234"]
        },
        "status": {
          "type": "string",
          "enum": ["queued", "processed", "failed"],
          "description": "Current status of the event",
          "examples": ["queued"]
        }
      },
      "required": ["event_id", "status"],
      "additionalProperties": false
    }
  },
  "required": ["message", "request_id", "event_created"],
  "additionalProperties": false
}