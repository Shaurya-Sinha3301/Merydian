# ============================================================================
# MeiliAI — Environment Variables Template
# Copy this file to .env and fill in all required values.
# DO NOT commit the real .env to source control.
# ============================================================================

# ── Application ─────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Security (REQUIRED) ──────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_in_production_at_least_32_chars

# ── PostgreSQL (REQUIRED) ────────────────────────────────────────────────────
POSTGRES_USER=meiliai
POSTGRES_PASSWORD=meiliai_secret
POSTGRES_DB=meiliai
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── API ports ────────────────────────────────────────────────────────────────
API_PORT=8000
FLOWER_PORT=5555

# ── AI Agents (at least one key required for FeedbackAgent to work) ─────────
GROQ_API_KEY=gsk_your_groq_api_key_here
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ── TBO Hotel API ────────────────────────────────────────────────────────────
TBO_API_URL=http://api.tbotechnology.in/TBOHolidays_HotelAPI
TBO_USERNAME=your_tbo_username
TBO_PASSWORD=your_tbo_password

# ── TBO Air API (optional) ───────────────────────────────────────────────────
TBO_AIR_BOOKING_URL=
TBO_AIR_SEARCH_URL=
TBO_AIR_USERNAME=
TBO_AIR_PASSWORD=

# ── Celery ───────────────────────────────────────────────────────────────────
CELERY_CONCURRENCY=4
UVICORN_WORKERS=2

# ── Flower Monitoring ────────────────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=admin
