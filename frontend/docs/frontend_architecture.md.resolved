## 4. Component Dependency Map

### How Components Connect

```mermaid
graph TD
    subgraph "Root"
        Layout["layout.tsx<br/>(AuthProvider)"]
    end

    subgraph "Public"
        LP["/ ‚Üí LandingPage"]
        CL["customer-login ‚Üí CustomerLoginInteractive"]
        AL["agent-login ‚Üí AgentLoginInteractive"]
        SU["signup ‚Üí (inline form)"]
    end

    subgraph "Customer Portal"
        CP["customer-portal ‚Üí EnhancedCustomerPortalInteractive"]
        CB["customer-bookings ‚Üí BookingCard + CustomerSidebar"]
        CPref["customer-preference ‚Üí PreferenceBuilderInteractive"]
        CTR["customer-trip-request ‚Üí TripRequestInteractive"]
        CIV["customer-itinerary-view ‚Üí CustomerItineraryInteractive"]
        CI["customer-itinerary/tripId ‚Üí ItineraryView"]
    end

    subgraph "Agent Dashboard"
        AIM["itinerary-management ‚Üí ItineraryOptimizerWindow"]
        AID["tripId ‚Üí ItineraryDetailView"]
        AIB["tripId/bookings ‚Üí BookingsView"]
        AIG["tripId/groups ‚Üí GroupsView"]
        AII["tripId/intelligence ‚Üí IntelligenceView"]
        AINew["new ‚Üí (inline form)"]
        AB["itinerary-builder ‚Üí ItineraryBuilderView"]
        ARR["agent-request-review ‚Üí AgentRequestReviewInteractive"]
        OPT["optimizer ‚Üí EditorInteractive"]
    end

    Layout --> LP
    Layout --> CL
    Layout --> AL
    Layout --> CP
    Layout --> AIM

    LP --> Header["components/landing/Header"]
    LP --> Hero["components/landing/HeroSection"]
    LP --> Features["components/landing/FeaturesSection"]
    LP --> Footer["components/landing/Footer"]

    CP --> TripCard["EnhancedTripCard"]
    CP --> ChatModal["EnhancedAgentChatModal"]
    CP --> PlanTrip["PlanTripModal"]

    CTR --> DestSel["DestinationSelector"]
    CTR --> DatePick["DateRangePicker"]
    CTR --> BudgetSldr["BudgetRangeSlider"]
    CTR --> GroupComp["GroupComposition"]
    CTR --> TravPref["TravelerPreferences"]

    AID --> TimelineCard["TimelineEventCard"]
    AID --> TicketModal["TicketModal"]
    AID --> VoyageurAI["VoyageurAIPanel"]

    AII --> Charts["charts/*"]
```

